{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "URL to the user's profile photo." },
        "settings": {
          "type": "object",
          "description": "User preferences and settings.",
          "properties": {
            "notifications": { "type": "boolean" },
            "emailAlerts": { "type": "boolean" },
            "healthReminders": { "type": "boolean" },
            "medicationReminders": { "type": "boolean" },
            "privacy": { "type": "boolean" },
            "history": { "type": "boolean" },
            "twoFactor": { "type": "boolean" },
            "advancedReasoning": { "type": "boolean" },
            "voiceFeedback": { "type": "boolean" },
            "highPerformance": { "type": "boolean" },
            "autoExport": { "type": "boolean" },
            "cloudSync": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "HealthAssessment": {
      "title": "Health Assessment",
      "description": "Stores a single health assessment result for a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who owns this assessment." },
        "metrics": {
          "type": "object",
          "description": "The raw health metrics used for the prediction."
        },
        "smokingProb": { "type": "number", "description": "Predicted probability of smoking." },
        "drinkingProb": { "type": "number", "description": "Predicted probability of drinking." },
        "insights": { "type": "string", "description": "AI-generated health insights." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the assessment was performed." }
      },
      "required": ["uid", "metrics", "smokingProb", "drinkingProb", "createdAt"]
    },
    "Complaint": {
      "title": "User Complaint",
      "description": "Stores user complaints or feedback.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the user." },
        "email": { "type": "string", "format": "email", "description": "The email of the user." },
        "subject": { "type": "string", "description": "The subject of the complaint." },
        "message": { "type": "string", "description": "The detailed complaint message." },
        "uid": { "type": "string", "description": "The ID of the user (if authenticated)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the complaint was submitted." }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Stores a single message in a chat conversation.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who owns this message." },
        "role": { "type": "string", "enum": ["user", "model"], "description": "The role of the message sender." },
        "content": { "type": "string", "description": "The text content of the message." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["uid", "role", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/assessments/{assessmentId}": {
      "schema": "HealthAssessment",
      "description": "Collection of health assessments."
    },
    "/complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "Collection of user complaints."
    },
    "/chats/{chatId}": {
      "schema": "ChatMessage",
      "description": "Collection of user chat messages."
    }
  }
}
